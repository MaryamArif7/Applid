{
  "manifest_version": 3,
  "name": "Applid",
  "version": "0.1.0",
  "description": "Silently tracks every Google Form you submit — your answers, timestamps, and status in one place.",

  "permissions": [
    "storage",
    "notifications"
  ],

  "host_permissions": [
    "https://docs.google.com/forms/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://docs.google.com/forms/*"],
      "js": ["src/content/index.js"],
      "run_at": "document_end"
    }
  ],

  "background": {
    "service_worker": "src/background/index.js"
  },

  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
